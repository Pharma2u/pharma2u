generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  customer
  vendor
  rider
  admin
}

enum ProductCategory {
  otc
  prescription
  schedule_h
}

enum OrderStatus {
  pending_verification
  verified
  rejected
  awaiting_rider
  rider_assigned
  picked_up
  relay_pending
  relay_failed
  on_the_way
  delivered
  cancelled
  disputed
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum PaymentMethod {
  upi
  card
  cod
}

enum RelayStatus {
  pending
  handoff_done
  failed
}

enum RefundStatus {
  pending
  processing
  completed
  failed
}

enum ReservationStatus {
  held
  committed
  released
}

model User {
  id                 String   @id @default(uuid())
  role               Role
  name               String
  phone              String   @unique
  email              String?  @unique
  passwordHash       String
  address            String? // legacy; use savedAddresses for new data
  mustChangePassword Boolean  @default(false)
  isActive           Boolean  @default(true)
  applicationStatus  String?
  rejectionReason    String?
  createdAt          DateTime @default(now())

  pharmacies         Pharmacy[]        @relation("VendorPharmacies")
  ordersAsCustomer   Order[]           @relation("CustomerOrders")
  ordersAsRider      Order[]           @relation("PrimaryRiderOrders")
  ordersAsRelayRider Order[]           @relation("RelayRiderOrders")
  riderLocation      RiderLocation?
  riderKyc           RiderKyc?
  savedAddresses     CustomerAddress[]
  reviews            ProductReview[]
  prescriptions      Prescription[]
  notifications      NotificationLog[]

  @@map("users")
}

model AdminAuditLog {
  id            String   @id @default(uuid())
  actingAdminId String
  createdUserId String
  action        String
  createdAt     DateTime @default(now())

  @@index([actingAdminId])
  @@index([createdUserId])
  @@map("admin_audit_logs")
}

model Pharmacy {
  id                      String                                @id @default(uuid())
  vendorUserId            String
  vendor                  User                                  @relation("VendorPharmacies", fields: [vendorUserId], references: [id])
  name                    String
  address                 String
  isOpen                  Boolean                               @default(true)
  logoPath                String?
  bannerPath              String?
  openingTime             String?
  closingTime             String?
  operatingDays           String[]                              @default([])
  location                Unsupported("geography(Point,4326)")?
  drugLicenseNumber       String
  pharmacistName          String
  pharmacistLicenseNumber String
  products                Product[]
  orders                  Order[]                               @relation("PrimaryPharmacyOrders")
  relayOrders             Order[]                               @relation("RelayPharmacyOrders")
  createdAt               DateTime                              @default(now())
  counterBills            CounterBill[]
  promotions              VendorPromotion[]
  payoutRequests          PayoutRequest[]
  vendorSettings          VendorSettings?

  @@index([vendorUserId])
  @@map("pharmacies")
}


model CounterBill {
  id                String            @id @default(uuid())
  pharmacyId        String
  pharmacy          Pharmacy          @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  billNumber        String            @unique
  customerReference String?
  paymentMethod     String
  subtotal          Float
  discount          Float             @default(0)
  total             Float
  createdAt         DateTime          @default(now())
  items             CounterBillItem[]

  @@index([pharmacyId, createdAt])
  @@map("counter_bills")
}

model CompanyProfile {
  id String @id @default("default")
  name String
  legalName String
  phone String
  email String
  address String
  city String
  state String
  pincode String
  gstin String
  registrationNumber String
  logoDataUrl String?
  updatedAt DateTime @updatedAt
  @@map("company_profiles")
}

model LedgerEntry {
  id String @id @default(uuid())
  reference String @unique
  description String
  division String
  type String
  amount Float
  status String @default("pending")
  entryDate DateTime @default(now())
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([division, entryDate])
  @@map("ledger_entries")
}

model AdminAnnouncement {
  id String @id @default(uuid())
  title String
  message String
  audience String
  publishedBy String
  publishedAt DateTime @default(now())
  @@index([publishedAt])
  @@map("admin_announcements")
}

model Employee {
  id String @id @default(uuid())
  employeeCode String @unique
  name String
  jobRole String
  department String
  monthlySalary Float
  status String @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([department, status])
  @@map("employees")
}

model SupportTicket {
  id String @id @default(uuid())
  ticketCode String @unique
  subject String
  requester String
  category String
  priority String @default("medium")
  status String @default("open")
  assignedTo String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([status, priority])
  @@map("support_tickets")
}

model PharmacySubscription {
  id String @id @default(uuid())
  pharmacyId String @unique
  plan String @default("Unconfigured")
  amount Float @default(0)
  nextBilling DateTime?
  autopay Boolean @default(false)
  status String @default("attention")
  updatedAt DateTime @updatedAt
  @@map("pharmacy_subscriptions")
}

model CounterBillItem {
  id            String      @id @default(uuid())
  counterBillId String
  counterBill   CounterBill @relation(fields: [counterBillId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  name          String
  qty           Int
  price         Float

  @@index([counterBillId])
  @@map("counter_bill_items")
}

model VendorPromotion {
  id           String   @id @default(uuid())
  pharmacyId   String
  pharmacy     Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  title        String
  code         String
  amountOff    Float
  minimumOrder Float     @default(0)
  startsAt     DateTime  @default(now())
  expiresAt    DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  @@unique([pharmacyId, code])
  @@index([pharmacyId, isActive])
  @@map("vendor_promotions")
}

model PayoutRequest {
  id         String   @id @default(uuid())
  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  amount     Float
  note       String
  status     String   @default("open")
  createdAt  DateTime @default(now())

  @@index([pharmacyId, createdAt])
  @@map("payout_requests")
}

model VendorSettings {
  id         String   @id @default(uuid())
  pharmacyId String   @unique
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  printerUrl String?
  autoPrint  Boolean  @default(true)
  updatedAt  DateTime @updatedAt

  @@map("vendor_settings")
}
model HomepageBanner {
  id        String   @id @default(uuid())
  title     String
  subtitle  String?
  imageUrl  String?
  linkUrl   String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("homepage_banners")
}
model Product {
  id                  String             @id @default(uuid())
  pharmacyId          String
  pharmacy            Pharmacy           @relation(fields: [pharmacyId], references: [id])
  name                String
  genericName         String
  category            ProductCategory    @default(otc)
  price               Float
  stock               Int
  unit                String
  imagePath           String? // legacy primary image; ProductImage is the source of truth
  description         String?
  manufacturer        String?
  packSize            String?
  mrp                 Float?
  discount            Float              @default(0)
  saltComposition     String?
  storageInstructions String?
  deliveryTime        Int?
  expiryDate          DateTime?
  batchNumber         String?
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  orderItems          OrderItem[]
  stockReservations   StockReservation[]
  images              ProductImage[]
  reviews             ProductReview[]
  counterBillItems    CounterBillItem[]

  @@index([pharmacyId, genericName])
  @@map("products")
}

model Order {
  deliveryOtp           String?
  deliveryOtpIssuedAt   DateTime?
  deliveryOtpVerifiedAt DateTime?
  id                    String             @id @default(uuid())
  pickupOtp             String?
  pickupOtpIssuedAt     DateTime?
  pickupOtpVerifiedAt   DateTime?
  orderCode             String             @unique
  customerId            String
  customer              User               @relation("CustomerOrders", fields: [customerId], references: [id])
  pharmacyId            String
  pharmacy              Pharmacy           @relation("PrimaryPharmacyOrders", fields: [pharmacyId], references: [id])
  status                OrderStatus        @default(pending_verification)
  requiresPrescription  Boolean            @default(false)
  prescriptionPath      String?
  ocrText               String?
  ocrConfidence         Float?
  subtotal              Float
  deliveryFee           Float
  total                 Float
  paymentStatus         PaymentStatus      @default(pending)
  paymentMethod         PaymentMethod      @default(cod)
  paymentRef            String?
  dropLat               Float?
  dropLng               Float?
  dropAddress           String
  deliveryInstructions  String?
  estimatedDeliveryTime DateTime?
  deliveredAt           DateTime?
  isRelay               Boolean            @default(false)
  relayPharmacyId       String?
  relayPharmacy         Pharmacy?          @relation("RelayPharmacyOrders", fields: [relayPharmacyId], references: [id])
  relayNodeLat          Float?
  relayNodeLng          Float?
  relayStatus           RelayStatus?
  relayPackedAt         DateTime?
  riderId               String?
  rider                 User?              @relation("PrimaryRiderOrders", fields: [riderId], references: [id])
  relayRiderId          String?
  relayRider            User?              @relation("RelayRiderOrders", fields: [relayRiderId], references: [id])
  cancelledReason       String?
  cancelledBy           String?
  cancelledAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  items                 OrderItem[]
  events                OrderEvent[]
  reservations          StockReservation[]
  payment               Payment?
  refund                Refund?

  @@index([status])
  @@index([customerId])
  @@index([riderId])
  @@index([pharmacyId, status])
  @@map("orders")
}

model OrderItem {
  id                String  @id @default(uuid())
  orderId           String
  order             Order   @relation(fields: [orderId], references: [id])
  productId         String
  product           Product @relation(fields: [productId], references: [id])
  fromRelayPharmacy Boolean @default(false)
  name              String
  qty               Int
  price             Float

  @@map("order_items")
}

model OrderEvent {
  id        String      @id @default(uuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id])
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  @@map("order_events")
}


model StockReservation {
  id        String            @id @default(uuid())
  orderId   String
  order     Order             @relation(fields: [orderId], references: [id])
  productId String
  product   Product           @relation(fields: [productId], references: [id])
  qty       Int
  status    ReservationStatus @default(held)
  expiresAt DateTime

  @@index([productId, status, expiresAt])
  @@map("stock_reservations")
}

model RiderLocation {
  riderId   String   @id
  rider     User     @relation(fields: [riderId], references: [id])
  lat       Float
  lng       Float
  isOnline  Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("rider_locations")
}

model RiderKyc {
  id                   String    @id @default(uuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id])
  aadharNumber         String
  aadharImagePath      String
  panNumber            String
  panImagePath         String
  drivingLicenseNumber String
  dlImagePath          String
  vehicleType          String
  vehicleNumber        String
  submittedAt          DateTime  @default(now())
  reviewedAt           DateTime?
  reviewedBy           String?

  @@map("rider_kyc")
}


model ProductImage {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  path      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([productId, path])
  @@index([productId, sortOrder])
  @@map("product_images")
}

model CustomerAddress {
  id          String   @id @default(uuid())
  customerId  String
  customer    User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label       String
  flatOrHouse String
  addressLine String
  landmark    String?
  city        String
  state       String
  pincode     String
  lat         Float?
  lng         Float?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
  @@map("customer_addresses")
}

model ProductReview {
  id         String   @id @default(uuid())
  productId  String
  customerId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer   User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, customerId])
  @@index([productId])
  @@map("product_reviews")
}

model Coupon {
  id           String    @id @default(uuid())
  code         String    @unique
  description  String?
  percentOff   Float?
  amountOff    Float?
  minimumOrder Float?
  startsAt     DateTime  @default(now())
  expiresAt    DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  @@map("coupons")
}

model NotificationLog {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   String
  template  String
  payload   Json?
  sentAt    DateTime?
  failedAt  DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@map("notification_logs")
}

model Refund {
  id          String       @id @default(uuid())
  orderId     String       @unique
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount      Float
  status      RefundStatus @default(pending)
  providerRef String?
  reason      String?
  errorReason String?
  rawPayload  Json?
  requestedAt DateTime     @default(now())
  processedAt DateTime?
  updatedAt   DateTime     @updatedAt

  @@map("refunds")
}

model Payment {
  id                String        @id @default(uuid())
  orderId           String        @unique
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider          String
  providerOrderId   String?       @unique
  providerPaymentId String?       @unique
  amount            Float
  currency          String        @default("INR")
  status            PaymentStatus @default(pending)
  failureReason     String?
  rawPayload        Json?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("payments")
}

model PaymentWebhookEvent {
  id          String    @id @default(uuid())
  provider    String
  eventId     String    @unique
  eventType   String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([provider, createdAt])
  @@map("payment_webhook_events")
}

model Prescription {
  id         String   @id @default(uuid())
  customerId String
  customer   User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  path       String
  note       String?
  createdAt  DateTime @default(now())

  @@index([customerId, createdAt])
  @@map("prescriptions")
}
model PharmacyApplication {
  id                      String   @id @default(uuid())
  ownerName               String
  ownerPhone              String   @unique
  pharmacyName            String
  address                 String
  lat                     Float
  lng                     Float
  drugLicenseNumber       String   @unique
  drugLicensePath         String
  pharmacistName          String
  pharmacistLicenseNumber String
  pharmacistLicensePath   String
  status                  String   @default("pending")
  rejectionReason         String?
  reviewedAt              DateTime?
  reviewedBy              String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([status, createdAt])
  @@map("pharmacy_applications")
}
